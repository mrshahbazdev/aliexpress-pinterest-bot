# Pinterest API
PINTEREST_ACCESS_TOKEN=your_pinterest_access_token_here
PINTEREST_BOARD_ID=your_board_id_here

# AI Provider (set at least one)
# Option 1: Google Gemini (recommended - free tier available)
GEMINI_API_KEY=your_gemini_api_key_here

# Option 2: OpenAI
OPENAI_API_KEY=your_openai_api_key_here

# AliExpress Affiliate Portal Session
# Copy these from your browser cookies when logged into portals.aliexpress.com
AE_COOKIE_XMAN_US_T=your_xman_us_t_cookie_value
AE_COOKIE_XMAN_US_F=your_xman_us_f_cookie_value
AE_TRACKING_ID=default

# Pin Settings
PIN_LANGUAGE=en
PIN_SHIP_TO=US
PIN_CURRENCY=USD

# Database (MySQL)
DB_HOST=your_db_host
DB_PORT=3306
DB_NAME=your_db_name
DB_USER=your_db_user
DB_PASSWORD=your_db_password
